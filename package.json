{
  "name": "n8n-nodes-exa-unofficial",
  "version": "1.0.5",
  "description": "Unofficial n8n node for Exa API - intelligent web search and content extraction",
  "keywords": [
    "n8n-community-node-package"
  ],
  "license": "MIT",
  "homepage": "https://github.com/SanderSpiegelaar/n8n-nodes-exa-unofficial",
  "author": {
    "name": "Sander Spiegelaar"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/SanderSpiegelaar/n8n-nodes-exa-unofficial.git"
  },
  "engines": {
    "node": ">=20.15"
  },
  "main": "dist/nodes/Exa/ExaUnofficial.node.js",
  "types": "dist/nodes/Exa/ExaUnofficial.node.d.ts",
  "scripts": {
    "format": "prettier nodes credentials --write",
    "lintfix": "eslint nodes credentials package.json --fix",
    "test": "npm run build && node --test tests/*.test.js",
    "build": "n8n-node build",
    "build:watch": "tsc --watch",
    "dev": "n8n-node dev",
    "lint": "n8n-node lint",
    "lint:fix": "n8n-node lint --fix",
    "test:watch": "vitest",
    "test:live": "vitest run test/live/Serper.live.ts",
    "scan:package": "node test/package-scan.mjs",
    "release": "n8n-node release",
    "prepublishOnly": "n8n-node prerelease"
  },
  "files": [
    "dist"
  ],
  "n8n": {
    "n8nNodesApiVersion": 1,
    "credentials": [
      "dist/credentials/ExaUnofficialApi.credentials.js"
    ],
    "nodes": [
      "dist/nodes/Exa/ExaUnofficial.node.js"
    ]
  },
  "devDependencies": {
    "@n8n/node-cli": "^0.39.3",
    "@typescript-eslint/parser": "^7.15.0",
    "eslint": "^8.56.0",
    "eslint-plugin-n8n-nodes-base": "^1.16.1",
    "gulp": "^4.0.2",
    "n8n-workflow": "^1.60.0",
    "prettier": "^3.3.2",
    "typescript": "^5.5.3"
  },
  "peerDependencies": {
    "n8n-workflow": "*"
  },
  "publishConfig": {
    "access": "public"
  }
}
